# ================================================================
# .env — 민감정보 환경변수
# Git에 절대 커밋하지 마세요. .gitignore에 .env 추가 필수!
# ================================================================

# ── Spring Boot REST API ─────────────────────────────────────────
SPRING_BASE_URL=http://127.0.0.1:8080

# ── FastAPI 서버 ─────────────────────────────────────────────────
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000

# ── MariaDB (Spring REST 우회 시 직접 접속용) ────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cafe_erp
DB_USER=root
DB_PASSWORD=root

# ── 엑셀 저장 경로 ───────────────────────────────────────────────
# 미설정 시 config.py 가 DAP 폴더 위치를 기준으로 자동 결정
# (ERP/DAP 구조에서는 ERP/src/main/resources/static/uploads/excel 로 자동 설정)
# 별도 경로 지정 시에만 아래 주석을 해제하고 수정하세요.
# EXCEL_OUTPUT_DIR=C:/Users/yourname/project/reports

#── 초기 자본 (재무상태표용) ─────────────────────────────────────
INITIAL_CAPITAL=100000000
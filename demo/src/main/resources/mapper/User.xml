<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.example.demo.mapper.UserMapper">

	<!-- PK 기준 조회 -->
	<select id="findById" parameterType="Long"
		resultType="com.example.demo.Domain.User">
		SELECT id, user_pw, is_active
		FROM users
		WHERE id = #{id}
	</select>

	<!-- emp_num 기준 조회 (참조용, 필요시 사용) -->
	<select id="findByEmpNum" parameterType="String"
		resultType="com.example.demo.Domain.User">
		SELECT id, user_pw, is_active
		FROM users
		WHERE id = (
		SELECT id
		FROM users
		WHERE emp_num = #{emp_num} -- emp_num은 User 객체 참조용 필드
		)
	</select>

	<!-- 전체 조회 -->
	<select id="findAll" resultType="com.example.demo.Domain.User">
		SELECT id, user_pw, is_active
		FROM users
	</select>

	<!-- 활성/비활성 토글 -->
	<update id="updateUserActive"
		parameterType="com.example.demo.Domain.User">
		UPDATE users
		SET is_active = #{is_active}
		WHERE id = #{id}
	</update>

	<!-- 신규 사용자 저장 (pw + is_active만) -->
	<insert id="save" parameterType="com.example.demo.Domain.User">
		INSERT INTO users(user_pw, is_active)
		VALUES(#{user_pw}, #{is_active})
	</insert>

</mapper>
